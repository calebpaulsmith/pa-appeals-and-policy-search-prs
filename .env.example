# ---------------------------------------------------------------------------
# pa-appeals-and-policy-search — example environment configuration
#
# Copy to `.env` (git-ignored) for local development, OR set these as
# Databricks App environment variables in the App UI for deployment.
#
# Leave APPEALS_VOLUME_PATH / DATABRICKS_WAREHOUSE_ID UNSET to run the app in
# DEMO MODE with fabricated placeholder records only. Populate them (and the
# index tables) to move into PILOT / PRODUCTION mode.
#
# NEVER commit a populated .env. NEVER put tokens or secrets in source control.
# ---------------------------------------------------------------------------

# --- Mode / index source -------------------------------------------------

# Absolute Unity Catalog volume root that contains the approved source PDFs.
# Must start with /Volumes/. The server allowlists this root and rejects any
# request that resolves outside of it (path-traversal protection).
# Leave blank for Demo Mode.
APPEALS_VOLUME_PATH=

# SQL warehouse that has READ access to the index tables. Leave blank for
# Demo Mode. (HTTP path is derived from the warehouse id.)
DATABRICKS_WAREHOUSE_ID=

# Fully-qualified index table names, e.g. catalog.schema.appeal_research_documents
DOCUMENTS_TABLE=
PAGES_TABLE=

# --- Databricks connection (provided automatically by App resources) -----
# For local dev only. In a deployed Databricks App these are injected by the
# attached SQL warehouse / volume resources and OAuth — do NOT hardcode them.
DATABRICKS_HOST=
# Personal access token for LOCAL development only. Never commit. Prefer
# OAuth / app resources in deployment.
DATABRICKS_TOKEN=

# --- App runtime ---------------------------------------------------------
# Databricks Apps inject the port to bind on via DATABRICKS_APP_PORT.
# PORT is a local-dev fallback. Do not hardcode a port in source.
# DATABRICKS_APP_PORT=8000
PORT=8080

# Path to the YAML config file (optional; env vars take precedence).
CONFIG_PATH=config.yaml
